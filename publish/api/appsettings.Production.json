{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "UseSqlite": false,
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:{SQL_SERVER_FQDN},1433;Initial Catalog={DATABASE_NAME};Persist Security Info=False;User ID=sqladmin;Password={PASSWORD};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "CORS_ALLOWED_ORIGINS": "https://littleaqualamp51.conveyor.cloud;https://{STATIC_WEB_APP_URL}",
  "Jwt": {
    "SecretKey": "ChangeMe_ChooseAStrongSecretKeyMinimum32Characters!",
    "Issuer": "BrigadeMedicaleAPI",
    "Audience": "BrigadeMedicaleClients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  }
}
