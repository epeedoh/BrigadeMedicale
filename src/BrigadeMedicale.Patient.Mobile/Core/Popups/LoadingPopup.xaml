<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="BrigadeMedicale.Patient.Mobile.Core.Popups.LoadingPopup"
    CanBeDismissedByTappingOutsideOfPopup="False">

    <!-- Semi-transparent overlay background -->
    <Grid BackgroundColor="#00000080" Padding="20">
        <Border
            StrokeShape="RoundRectangle 12,12,12,12"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}"
            Stroke="{AppThemeBinding Light={StaticResource InputBorderLight}, Dark={StaticResource InputBorderDark}}"
            StrokeThickness="1"
            Padding="24"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="200">

            <VerticalStackLayout Spacing="16" HorizontalOptions="Center" VerticalOptions="Center">
                <ActivityIndicator
                    IsRunning="True"
                    IsVisible="True"
                    Color="{StaticResource Primary}"
                    WidthRequest="48"
                    HeightRequest="48"
                    HorizontalOptions="Center" />

                <Label
                    x:Name="MessageLabel"
                    Text="Chargement..."
                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                    FontSize="14"
                    FontFamily="OpenSansRegular"
                    HorizontalTextAlignment="Center"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</toolkit:Popup>
